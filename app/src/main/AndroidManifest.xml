<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- PERMISSÕES CORRETAS -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!-- REMOVIDO: BATTERY_STATS (inútil para apps comuns) -->

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.AppCompat.Light"
        tools:targetApi="tiramisu">

        <!-- Serviço interno (mantido) -->
        <service
            android:name=".BatteryService"
            android:exported="false" />

        <!-- Receiver para bateria (mantido, exportado corretamente) -->
        <receiver
            android:name=".BatteryReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BATTERY_CHANGED" />
            </intent-filter>
        </receiver>

        <!-- Serviço em foreground com tipo corrigido -->
        <service
            android:name=".BatteryMonitorService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <!-- Justificativa obrigatória para "specialUse" na Play Store -->
            <property
                android:name="android.foreground_service_type_special_use"
                android:value="Monitoramento contínuo do nível da bateria para notificar o usuário sobre economia de energia." />
        </service>

        <!-- Activity principal (mantida) -->
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

    </application>

</manifest>
